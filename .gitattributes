# Force LF line endings for shell scripts (critical for Linux containers)
*.sh text eol=lf
docker/**/*.sh text eol=lf
docker/**/*.js text eol=lf
# Git LFS tracking for world snapshot binaries
docker/worlds/**/*.db filter=lfs diff=lfs merge=lfs -text
docker/worlds/**/*.png filter=lfs diff=lfs merge=lfs -text
docker/worlds/**/*.jpg filter=lfs diff=lfs merge=lfs -text
docker/worlds/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
docker/worlds/**/*.gif filter=lfs diff=lfs merge=lfs -text
docker/worlds/**/*.webp filter=lfs diff=lfs merge=lfs -text
docker/worlds/**/*.svg filter=lfs diff=lfs merge=lfs -text
docker/worlds/**/*.mp3 filter=lfs diff=lfs merge=lfs -text
docker/worlds/**/*.ogg filter=lfs diff=lfs merge=lfs -text
docker/worlds/**/*.wav filter=lfs diff=lfs merge=lfs -text
docker/worlds/**/*.mp4 filter=lfs diff=lfs merge=lfs -text
docker/worlds/**/*.webm filter=lfs diff=lfs merge=lfs -text
docker/worlds/**/*.pdf filter=lfs diff=lfs merge=lfs -text
docker/worlds/**/*.zip filter=lfs diff=lfs merge=lfs -text
docker/worlds/**/*.ldb filter=lfs diff=lfs merge=lfs -text
docker/worlds/**/*.log filter=lfs diff=lfs merge=lfs -text
docker/worlds/**/MANIFEST-* filter=lfs diff=lfs merge=lfs -text
