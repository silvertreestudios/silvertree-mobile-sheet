# =============================================================================
# Local Podman E2E Environment
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- FoundryVTT Credentials (required) ---
# Your FoundryVTT.com account username and password.
# Used by the felddy/foundryvtt image to download FoundryVTT on first run.
FOUNDRY_USERNAME=
FOUNDRY_PASSWORD=

# Your FoundryVTT license key. Required to accept the EULA.
FOUNDRY_LICENSE_KEY=

# --- World Configuration ---
# Name of the world folder inside docker/worlds/ to auto-launch.
# Must match the folder name exactly (e.g., "my-campaign").
FOUNDRY_WORLD=

# --- FoundryVTT Admin ---
# Password for FoundryVTT's admin panel. Defaults to "admin" for local dev.
FOUNDRY_ADMIN_KEY=admin

# --- Relay Configuration ---
# Shared API key used to authenticate between FoundryVTT module and relay.
# On first run, start the stack, visit http://localhost:3010 to create an
# account and generate an API key, then paste it here and restart.
RELAY_API_KEY=

# WebSocket URL the FoundryVTT REST API module uses to connect to the relay.
# IMPORTANT: The REST API module runs CLIENT-SIDE in the GM's browser, NOT
# inside the Foundry container. Use localhost (not the container name "relay").
RELAY_URL=ws://localhost:3010/

# REST API URL the mobile app uses to reach the relay server from the host.
MOBILE_RELAY_URL=http://localhost:3010
